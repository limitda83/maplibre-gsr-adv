    "@deck.gl/mapbox": "^8.9.0",
    "@luma.gl/core": "^8.5.10",
    "maplibre-gl": "^5.0.0"
  },
  "dependencies": {
    "deck.gl-particle": "^1.1.0"
  },
  "devDependencies": {
    "@deck.gl/core": "8.9.36",
    "@deck.gl/layers": "8.9.36",
    "@deck.gl/mapbox": "8.9.36",
    "@luma.gl/core": "^8.5.21",
    "geotiff": "^2.1.3",
    "maplibre-gl": "^5.10.0",
    "vite": "^7.3.1"
  }
