{
  "name": "maplibre-gsr-adv",
  "version": "0.1.0",
  "description": "MapLibre particle advection layer with speed-based color ramp (deck.gl + mapbox overlay)",
  "type": "module",
  "main": "./dist/maplibre-gsr-adv.cjs",
  "module": "./dist/maplibre-gsr-adv.js",
  "exports": {
    ".": {
      "import": "./dist/maplibre-gsr-adv.js",
      "require": "./dist/maplibre-gsr-adv.cjs"
    },
    "./ramp.css": "./src/ramp.css"
  },
  "files": [
    "dist",
    "src/ramp.css",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "maplibre",
    "deck.gl",
    "particle",
    "advection",
    "wind"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@deck.gl/core": "^8.9.0",
    "@deck.gl/layers": "^8.9.0",
    "@deck.gl/mapbox": "^8.9.0",
    "@luma.gl/core": "^8.5.10",
    "maplibre-gl": "^5.0.0"
  },
  "dependencies": {
    "deck.gl-particle": "^1.1.0"
  },
  "devDependencies": {
    "@deck.gl/core": "8.9.36",
    "@deck.gl/layers": "8.9.36",
    "@deck.gl/mapbox": "8.9.36",
    "@luma.gl/core": "^8.5.21",
    "maplibre-gl": "^5.10.0",
    "vite": "^7.3.1"
  }
}
