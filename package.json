    "LICENSES"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "example": "vite example",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "maplibre",
    "deck.gl",
    "particle",
    "advection",
    "wind"
  ],
  "author": "youngmin",
  "license": "MIT AND MPL-2.0",
